# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string. Include ?sslmode=require for Neon.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Must be at least 32 characters in production.
JWT_SECRET=your-super-secret-key-min-32-chars
# Token expiry — e.g. 7d, 24h, 3600s
JWT_EXPIRES_IN=7d

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Full URL of the deployed frontend — used for CORS and email links
FRONTEND_URL=https://your-frontend-domain.com

# ─── AWS (S3 for file storage, SES for transactional email) ──────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
# Verified sender address in AWS SES
AWS_SES_FROM_EMAIL=noreply@your-domain.com
AWS_SES_NAME=YourAppName
